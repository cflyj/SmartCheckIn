# 复制本文件为 .env 后填写（.env 已加入 .gitignore，勿提交）

# API 端口，需与 Vite 代理一致（可在 .env.development 里为前端单独写 API_PORT）
API_PORT=3001

# --- 人脸比对（服务端） ---
# L2 距离阈值：越小越严；默认见 docs/FACE_VERIFICATION_HARDENING_PRD.md 与 server/services/faceVerify.js
# FACE_MATCH_DISTANCE_THRESHOLD=0.42
# 客户端上报 TinyFace 分数下限（仅当请求含 detection_score 时校验）
# FACE_MIN_PROBE_DETECTION_SCORE=0.55
# 必须为 1/true 时：请求须带合法 detection_score（全站升级新版前端后可用）
# FACE_REQUIRE_DETECTION_SCORE=

# --- 人脸采样（前端 Vite，需重新 build）---
# TinyFaceDetector scoreThreshold、客户端拒绝提交的最小置信度
# VITE_FACE_DETECTOR_SCORE_THRESHOLD=0.5
# VITE_FACE_MIN_DETECTION_SCORE=0.55
